{
  "name": "trade-review-candle-by-candle",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "encyclopedia:build": "python3 scripts/encyclopedia/build_index.py --pdf \"$ENCYCLOPEDIA_PDF\" --out public/encyclopedia-data --resume",
    "encyclopedia:build:sample": "python3 scripts/encyclopedia/build_index.py --pdf \"$ENCYCLOPEDIA_PDF\" --out public/encyclopedia-data --from 1 --to 200",
    "encyclopedia:previews": "python3 scripts/encyclopedia/build_index.py --pdf \"$ENCYCLOPEDIA_PDF\" --out public/encyclopedia-data --previews-only",
    "encyclopedia:chart-scores": "python3 scripts/encyclopedia/build_index.py --pdf \"$ENCYCLOPEDIA_PDF\" --out public/encyclopedia-data --chart-scores-only",
    "encyclopedia:learn": "python3 scripts/encyclopedia/build_knowledge.py --out public/encyclopedia-data --resume"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "lightweight-charts": "^5.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
