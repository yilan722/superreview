# Get your key at https://financialmodelingprep.com/developer/docs
VITE_FMP_API_KEY=your_fmp_api_key_here

# Vercel Blob CDN（部署后填写，本地 dev 也可指向同一 CDN）
# 例：https://xxxxxxxx.public.blob.vercel-storage.com
VITE_ENCYCLOPEDIA_BASE_URL=

# 仅 upload 脚本使用，不要加 VITE_ 前缀，不要提交到 Git
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
